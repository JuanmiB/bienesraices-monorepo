{
  "name": "bienesraices-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "concurrently -n \"frontend,backend\" -c \"cyan,green\" \"pnpm --filter @bienesraices/frontend dev\" \"pnpm --filter @bienesraices/backend dev\"",
    "dev:frontend": "pnpm --filter @bienesraices/frontend dev",
    "dev:backend": "pnpm --filter @bienesraices/backend dev",
    "build": "pnpm -r --if-present build",
    "build:frontend": "pnpm --filter @bienesraices/frontend build",
    "test": "pnpm -r --if-present test",
    "test:frontend": "pnpm --filter @bienesraices/frontend test",
    "lint": "pnpm -r --if-present lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "install:all": "pnpm install",
    "typecheck": "tsc --noEmit -p packages/shared-types/tsconfig.json"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  }
}
